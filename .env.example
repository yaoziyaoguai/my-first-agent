# LLM Processing MVP provider config.
# Copy to .env locally if needed. Do not commit real .env files or secret values.

# Default offline provider for tests and local no-key runs.
MY_FIRST_AGENT_LLM_PROVIDER=fake
LLM_FAKE_MODEL=fake-llm

# Real provider example. Fill values only in your local .env.
# MY_FIRST_AGENT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# ANTHROPIC_BASE_URL=

# Optional generic fallbacks used by supported real providers.
# MY_FIRST_AGENT_LLM_MODEL=
# MY_FIRST_AGENT_LLM_BASE_URL=
